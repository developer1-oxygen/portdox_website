
#Options +FollowSymLinks -MultiViews 
#RewriteEngine On
#RewriteBase / 

# Externally redirect to remove .php extension
#RewriteCond %{THE_REQUEST} \s/([^.]+)\.php [NC]
#RewriteRule ^ /%1 [R=301,L]

# Internally redirect to handle requests without .php extension
#RewriteCond %{REQUEST_FILENAME}.php -f
#RewriteRule ^([^.]+)$ $1.php [L]
        